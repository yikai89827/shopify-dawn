{% layout 'theme' %}

<div class="page-width about-us-page" style="background-image: url('{{ '2.png' | asset_img_url: '2000x' }}')">
  <!-- 封面横幅 -->
  <div class="about-hero" style="background-image: url('{{ '3.png' | asset_img_url: '2000x' }}')">
    <div class="hero-content">
      <h1>{{ page.title }}</h1>
      <p>传承风水智慧 · 缔造和谐空间</p>
    </div>
  </div>

  <!-- 品牌故事 -->
  <section class="about-section">
    <div class="image-wrapper">
      <img src="{{ '1.png' | asset_img_url: '800x' }}" alt="品牌故事" loading="lazy" width="800" height="800">
    </div>
    <div class="content-wrapper">
      <h2>品牌故事</h2>
      <div class="content-box">
        <p>创立于2023年，我们致力于将中国传统风水智慧与现代空间设计完美融合，打造和谐宜居的环境。</p>
        <p>每一项风水布局都凝聚着专家的智慧，从勘测到设计，我们坚持传统风水理论与现代科学的结合。</p>
      </div>
    </div>
  </section>

  <!-- 设计理念 -->
  <section class="about-section reverse">
    <div class="image-wrapper">
      <img
        src="{{ '1.png' | asset_img_url: '800x' }}"
        alt="设计理念"
        loading="lazy"
        width="800"
        height="800"
      >
    </div>
    <div class="content-wrapper">
      <h2>设计理念</h2>
      <div class="content-box">
        <p>我们以"天人合一"为核心理念，从《易经》、风水典籍中汲取智慧。</p>
        <p>运用罗盘、五行等传统工具，结合现代空间规划，打造符合当代需求的风水布局。</p>
      </div>
    </div>
  </section>

  <!-- 匠人团队 -->
  <section class="craftsmen-section">
    <h2>匠人团队</h2>
    <div class="craftsmen-grid">
      <div class="craftsman-card">
        <img
          src="{{ 'craftsman-1.jpg' | asset_img_url: '400x' }}"
          alt="首席风水师"
          loading="lazy"
          width="400"
          height="400"
        >
        <h3>李明月</h3>
        <p>
          首席风水师<br>
          15年风水勘测经验
        </p>
      </div>
      <div class="craftsman-card">
        <img
          src="{{ 'craftsman-2.jpg' | asset_img_url: '400x' }}"
          alt="风水大师"
          loading="lazy"
          width="400"
          height="400"
        >
        <h3>马道长</h3>
        <p>
          风水大师<br>
          杨公风水传人
        </p>
      </div>
      <div class="craftsman-card">
        <img
          src="{{ 'craftsman-3.jpg' | asset_img_url: '400x' }}"
          alt="环境专家"
          loading="lazy"
          width="400"
          height="400"
        >
        <h3>王玉洁</h3>
        <p>
          环境专家<br>
          建筑风水规划师
        </p>
      </div>
    </div>
  </section>

  <!-- 联系我们 -->
  <section class="contact-section">
    <h2>联系我们</h2>
    <div class="contact-info">
      <p>邮箱：service@puzzlezen.com</p>
      <p>电话：400-888-XXXX</p>
      <p>地址：中国上海市黄浦区文化街88号</p>
    </div>
  </section>
</div>

<style>
  /* 保持原有样式不变 */
  .about-us-page {
    max-width: 1400px;
  }

  .about-hero {
    height: 500px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    margin-bottom: 60px;
  }

  .about-hero::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.3);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    color: white;
  }

  .hero-content h1 {
    font-size: 3em;
    margin-bottom: 20px;
    font-family: 'SimSun', serif;
  }

  .hero-content p {
    font-size: 1.5em;
    letter-spacing: 5px;
  }

  .about-section {
    display: flex;
    align-items: center;
    margin-bottom: 80px;
    gap: 50px;
  }

  .about-section.reverse {
    flex-direction: row-reverse;
  }

  .image-wrapper {
    flex: 1;
  }

  .image-wrapper img {
    width: 100%;
    border-radius: 4px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
  }

  .content-wrapper {
    flex: 1;
  }

  .content-wrapper h2 {
    font-size: 2em;
    margin-bottom: 30px;
    position: relative;
    font-family: 'SimSun', serif;
  }

  .content-wrapper h2::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 0;
    width: 80px;
    height: 2px;
    background: {{ settings.color_button_bg }};
  }

  .content-box {
    background: #f9f5f0;
    padding: 30px;
    border-radius: 4px;
    line-height: 1.8;
  }

  .content-box p {
    margin-bottom: 15px;
  }

  .craftsmen-section {
    text-align: center;
    margin: 100px 0;
  }

  .craftsmen-section h2 {
    font-size: 2em;
    margin-bottom: 50px;
    font-family: 'SimSun', serif;
  }

  .craftsmen-grid {
    display: flex;
    justify-content: center;
    gap: 30px;
    flex-wrap: wrap;
  }

  .craftsman-card {
    width: 300px;
    text-align: center;
  }

  .craftsman-card img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 50%;
    margin-bottom: 20px;
    border: 5px solid #f9f5f0;
  }

  .craftsman-card h3 {
    font-size: 1.3em;
    margin-bottom: 10px;
    color: {{ settings.color_heading }};
  }

  .craftsman-card p {
    color: #666;
  }

  .contact-section {
    text-align: center;
    margin: 80px 0;
  }

  .contact-section h2 {
    font-size: 2em;
    margin-bottom: 30px;
    font-family: 'SimSun', serif;
  }

  .contact-info {
    background: #f9f5f0;
    padding: 40px;
    max-width: 600px;
    margin: 0 auto;
    border-radius: 4px;
  }

  .contact-info p {
    margin-bottom: 15px;
    font-size: 1.1em;
  }

  @media (max-width: 749px) {
    .about-section, .about-section.reverse {
      flex-direction: column;
    }

    .hero-content h1 {
      font-size: 2em;
    }

    .hero-content p {
      font-size: 1em;
    }

    .craftsman-card {
      width: 100%;
      max-width: 300px;
    }
  }
</style>

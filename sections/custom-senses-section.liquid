{%- liquid
  assign heading = section.settings.heading
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
  assign featured_product = section.settings.featured_product
-%}
<div class="senses-section">
  <div class="featured-product-container">
    {% if section.settings.featured_product != blank %}
      {% assign product = all_products[section.settings.featured_product] %}
      <div class="featured-product">
        <div class="featured-product-image">
          {{ product.featured_image | image_url: width: 600 | image_tag }}
        </div>
        <div class="featured-product-info">
          <h3>{{ product.title }}</h3>
          {% if product.metafields.custom.series_name != blank %}
            <p class="product-series">{{ product.metafields.custom.series_name }}</p>
          {% endif %}
          <div class="product-price">
            {{ product.price | money }}
            {% if product.compare_at_price > product.price %}
              <span class="compare-price">{{ product.compare_at_price | money }}</span>
            {% endif %}
          </div>
          <a href="{{ product.url }}" class="button">Shop Senses</a>
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .featured-product-container {
    margin-bottom: 50px;
  }

  .featured-product {
    display: flex;
    gap: 40px;
    align-items: center;
  }

  .featured-product-image {
    flex: 1;
  }

  .featured-product-image img {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .featured-product-info {
    flex: 1;
  }

  .product-series {
    color: #666;
    font-size: 1.2rem;
    margin: 10px 0;
  }

  .product-price {
    font-size: 1.5rem;
    font-weight: bold;
    margin: 15px 0;
    padding: 10px 15px;
    background-color: rgba(0, 0, 0, 0.7);
    color: white;
    display: inline-block;
    border-radius: 4px;
  }

  .compare-price {
    text-decoration: line-through;
    color: #ccc;
    font-size: 1rem;
    margin-left: 10px;
  }

  .button {
    background-color: rgba(0, 0, 0, 0.7);
    color: white;
    padding: 12px 24px;
    border-radius: 4px;
    text-decoration: none;
    display: inline-block;
    transition: background-color 0.3s ease;
  }

  .button:hover {
    background-color: rgba(0, 0, 0, 0.9);
  }

  .product-grid-container {
    margin-top: 40px;
  }
</style>

{% schema %}
{
  "name": "Senses Section",
  "settings": [
    {
      "type": "product",
      "id": "featured_product",
      "label": "Featured Product"
    }
  ],
  "presets": [
    {
      "name": "Senses Section"
    }
  ]
}
{% endschema %}

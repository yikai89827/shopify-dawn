{% schema %}
{
  "name": "天轨八卦风水布局-1",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "大标题",
      "default": "天轨八卦风水布局"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "背景图片"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "内容",
      "default": "<p>在此输入风水布局内容</p>"
    }
  ],
  "presets": [
    {
      "name": "天轨八卦风水布局",
      "category": "风水布局"
    }
  ]
}
{% endschema %}

<div class="fengshui-celestial-section">
  <div class="page-width" style="background-image: url('{{ section.settings.bg_image | img_url: '2000x' }}');">
    <h2 class="celestial-title">{{ section.settings.title }}</h2>
    <div class="celestial-content">
      {{ section.settings.content }}
    </div>
  </div>
</div>

<style>
  .fengshui-celestial-section {
    padding: 60px 0;
    position: relative;
    min-height: 500px;
  }

  .bg-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    z-index: 10;
    opacity: 0.7;
  }

  .page-width {
    position: relative;
    z-index: 11;
  }

  .celestial-title {
    text-align: center;
    font-size: 2.2rem;
    color: #5c3a21;
    margin-bottom: 30px;
  }

  .celestial-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 30px;
    background: transparent;
    border-radius: 8px;
  }

  @media (max-width: 768px) {
    .fengshui-celestial-section {
      padding: 30px 0;
      min-height: 300px;
    }

    .celestial-title {
      font-size: 1.8rem;
    }
  }
</style>

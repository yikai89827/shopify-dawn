{% schema %}
{
  "name": "风水智慧区块",
  "settings": [
    {
      "type": "text",
      "id": "title_line",
      "label": "标题",
      "default": "Where Walls Whisper Wisdom"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "主展示图片"
    }
  ],
  "presets": [
    {
      "name": "风水智慧区块",
      "category": "自定义区块"
    }
  ]
}
{% endschema %}

<div class="fengshui-wisdom-section">
  <div class="page-width">
    <div class="wisdom-display">
      <h2 class="wisdom-line">{{ section.settings.title_line }}</h2>
      {% if section.settings.main_image != blank %}
        <div class="main-display">
          <img
            src="{{ section.settings.main_image | img_url: '1200x' }}"
            alt="风水智慧展示"
            width="1200"
            height="800"
            loading="lazy"
          >
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .fengshui-wisdom-section {
    padding: 60px 0;
    background: linear-gradient(135deg, #f5f0e6 0%, #e8d9c5 100%);
  }

  .wisdom-display {
    position: relative;
  }

  .wisdom-line {
    font-size: 3rem;
    color: #fff;
    font-weight: 400;
    position: absolute;
    top: 50%;
    right: 15px;
    transform: translateY(-50%);
    text-align: right;
  }

  .main-display {
    margin-bottom: 40px;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .main-display img {
    width: 100%;
    height: auto;
    display: block;
  }
</style>

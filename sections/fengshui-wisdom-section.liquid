{% schema %}
{
  "name": "风水智慧区块",
  "settings": [
    {
      "type": "text",
      "id": "title_line",
      "label": "标题",
      "default": "Where Walls Whisper Wisdom"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "主展示图片"
    }
  ],
  "presets": [
    {
      "name": "风水智慧区块",
      "category": "自定义区块"
    }
  ]
}
{% endschema %}

<div class="fengshui-wisdom-section">
  <div class="page-width">
    <div class="wisdom-header">
      <h2 class="wisdom-line">{{ section.settings.title_line }}</h2>
    </div>

    <div class="wisdom-display">
      {% if section.settings.main_image != blank %}
        <div class="main-display">
          <img
            src="{{ section.settings.main_image | img_url: '1200x' }}"
            alt="风水智慧展示"
            width="1200"
            height="800"
            loading="lazy"
          >
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .fengshui-wisdom-section {
    padding: 60px 0;
    background: linear-gradient(135deg, #f5f0e6 0%, #e8d9c5 100%);
    position: relative;
  }

  .wisdom-header {
    text-align: center;
    margin-bottom: 30px;
    position: absolute;
    top: 15px;
    transform: translateY(-50%);
    text-align: right;
  }

  .wisdom-line {
    font-size: 2rem;
    color: #fff;
    margin-bottom: 10px;
    font-weight: 400;
  }

  .wisdom-description {
    max-width: 800px;
    margin: 0 auto 40px;
    text-align: center;
    font-size: 1.5rem;
    line-height: 1.8;
    color: #555;
  }

  .main-display {
    margin-bottom: 40px;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
  }

  .main-display img {
    width: 100%;
    height: auto;
    display: block;
  }

  .item-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .wisdom-item {
    text-align: center;
    background: white;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
  }

  .wisdom-item:hover {
    transform: translateY(-5px);
  }

  .wisdom-item img {
    width: 100%;
    height: auto;
    border-radius: 4px;
    margin-bottom: 15px;
  }

  .item-label {
    font-size: 1rem;
    color: #8b4513;
    margin: 0;
    font-family: 'KaiTi', serif;
  }

  @media (max-width: 768px) {
    .wisdom-line1 {
      font-size: 1.8rem;
    }
    .wisdom-line2 {
      font-size: 1.3rem;
    }
    .wisdom-line3 {
      font-size: 2rem;
    }
  }
</style>

{%- liquid
  assign image = section.settings.image
  assign video = section.settings.video
  assign heading = section.settings.heading
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
-%}

<div class="hero-section">
  {% if video != blank %}
    <video class="hero-media" autoplay muted loop>
      <source src="{{ video | video_tag }}" type="video/mp4">
    </video>
  {% elsif image != blank %}
    {{ image | image_url: width: 2000 | image_tag: class: 'hero-media' }}
  {% endif %}

  <div class="hero-content">
    <h1 class="hero-heading">{{ heading }}</h1>
    <a href="{{ cta_link }}" class="button hero-cta">{{ cta_text }}</a>
  </div>
</div>

{% schema %}
{
  "name": "英雄区块",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "背景图片"
    },
    {
      "type": "video",
      "id": "video",
      "label": "背景视频"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "标题",
      "default": "光之转折"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "按钮文字",
      "default": "探索这个季节"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "按钮链接"
    }
  ],
  "presets": [
    {
      "name": "英雄区块"
    }
  ]
}
{% endschema %}

{%- liquid
  assign heading = section.settings.heading
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
  assign featured_ritual = section.settings.featured_ritual
  assign library_teaser = section.settings.library_teaser
-%}

<div class="rituals-section">
  <h2 class="section-heading">{{ heading }}</h2>

  <div class="featured-ritual">
    <h3>本月特色仪式</h3>
    <div class="ritual-content">
      {{ featured_ritual }}
    </div>
  </div>

  <div class="library-teaser">
    <h3>图书馆预告</h3>
    <p>{{ library_teaser }}</p>
  </div>

  <a href="{{ cta_link }}" class="button">{{ cta_text }}</a>
</div>

{% schema %}
{
  "name": "Rituals Preview",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "区块标题",
      "default": "Rituals Preview"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "按钮文字",
      "default": "Explore Rituals "
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "按钮链接"
    },
    {
      "type": "richtext",
      "id": "featured_ritual",
      "label": "特色仪式内容"
    },
    {
      "type": "text",
      "id": "library_teaser",
      "label": "图书馆预告"
    }
  ],
  "presets": [
    {
      "name": "Rituals Preview"
    }
  ]
}
{% endschema %}

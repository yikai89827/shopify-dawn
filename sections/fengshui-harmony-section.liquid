{% schema %}
{
  "name": "和谐保护风水布局",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "Harmony & Protection Formation"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "背景图片"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "内容",
      "default": "<p>在此添加和谐保护风水布局的详细说明</p>"
    }
  ],
  "presets": [
    {
      "name": "和谐保护风水布局",
      "category": "风水布局"
    }
  ]
}
{% endschema %}

<div
  class="fengshui-harmony-section"
  {% if section.settings.bg_image != blank %}
    style="background-image: url('{{ section.settings.bg_image | img_url: '2000x' }}');"
  {% endif %}
>
  <div class="page-width harmony-container">
    <h2 class="harmony-title">{{ section.settings.title }}</h2>
    {% comment %}
      <div class="harmony-content">
        {{ section.settings.content }}
      </div>
    {% endcomment %}
  </div>
</div>

<style>
  .fengshui-harmony-section {
    padding: 20px 0 60px;
    background-size: cover;
    background-position: center;
    min-height: 400px;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    position: relative;
  }
  .fengshui-harmony-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: transparent;
    z-index: 0;
  }
  .fengshui-harmony-section .page-width {
    position: relative;
    z-index: 1;
    text-align: center;
  }
  .harmony-container {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .harmony-title {
    font-size: 3rem;
    color: #fff;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.1);
    margin: 0;
  }
  .harmony-content {
    background-color: rgba(249, 245, 240, 0.9);
    padding: 30px;
    border-radius: 8px;
  }
  .harmony-content p {
    margin: 0 0 15px 0;
    font-size: 1.1rem;
    line-height: 1.6;
    color: #5c3a21;
  }
  @media (max-width: 768px) {
    .harmony-title {
      font-size: 2.2rem;
      margin-top: 60px;
    }
    .fengshui-harmony-section {
      padding: 80px 0 40px;
      min-height: 300px;
    }
  }
</style>

{% schema %}
{
  "name": "Serenity Love Cocoon",
  "settings": [
    {
      "type": "image_picker",
      "id": "cocoon_image",
      "label": "背景图片"
    }
  ],
  "presets": [
    {
      "name": "Serenity Love Cocoon",
      "category": "特殊布局"
    }
  ]
}
{% endschema %}

<div class="cocoon-container">
  {% if section.settings.cocoon_image != blank %}
    <img
      width="100%"
      height="auto"
      src="{{ section.settings.cocoon_image | img_url: '2000x' }}"
      alt="Serenity Love Cocoon"
      class="cocoon-image"
    >
    <div class="cocoon-words">
      <span class="word serenity">Serenity</span>
      <span class="word love">Love</span>
      <span class="word cocoon">Cocoon</span>
    </div>
  {% endif %}
</div>

<style>
  .cocoon-container {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .cocoon-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cocoon-words {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .word {
    font-size: 4rem;
    font-weight: 300;
    color: white;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.3);
    mix-blend-mode: overlay;
    opacity: 0.9;
    margin: 1rem 0;
  }
  .word.serenity {
    animation: float 3s ease-in-out infinite;
    position: absolute;
    top:40%;
    left 15px;
  }
  .word.love {
    animation: float 3s ease-in-out infinite 0.5s;
    position: absolute;
    top: 15px;
    left 40%;
  }
  .word.cocoon {
    animation: float 3s ease-in-out infinite 1s;
    position:absolute;
    top: 40%;
    right 15px;
  }

  @media (max-width: 768px) {
    .word {
      font-size: 2.5rem;
    }
  }
</style>

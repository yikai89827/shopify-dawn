{%- liquid
  assign heading = section.settings.heading
  assign slogan = section.settings.slogan
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
  assign background = section.settings.background
-%}

<div class="community-section">
  {% if background != blank %}
    {{ background | image_url: width: 2000 | image_tag: class: 'community-bg' }}
  {% endif %}

  <div class="community-content">
    <h2 class="section-heading">{{ heading }}</h2>
    <p class="slogan">{{ slogan }}</p>
    <a href="{{ cta_link }}" class="button">{{ cta_text }}</a>
  </div>
</div>

{% schema %}
{
  "name": "Community Preview",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "区块标题",
      "default": "Community Preview"
    },
    {
      "type": "text",
      "id": "slogan",
      "label": "标语",
      "default": "Built on what we share."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "按钮文字",
      "default": "Gather Community"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "按钮链接"
    },
    {
      "type": "image_picker",
      "id": "background",
      "label": "背景图片"
    }
  ],
  "presets": [
    {
      "name": "Community Preview"
    }
  ]
}
{% endschema %}

{% schema %}
{
  "name": "关于我们布局1",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "Fortune & Career Flow Formation"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "按钮链接"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "背景图片"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "背景颜色",
      "default": "#F9F5F0"
    },
    {
      "type": "image_picker",
      "id": "content_image",
      "label": "内容图片"
    },
    {
      "type": "richtext",
      "id": "content_text",
      "label": "内容描述",
      "default": "<p>在这里添加事业财富风水布局的详细描述</p>"
    }
  ],
  "presets": [
    {
      "name": "事业财富风水布局",
      "category": "风水布局"
    }
  ]
}
{% endschema %}

<div
  class="fengshui-career-section"
  {% if section.settings.bg_image != blank %}
    style="background-image: url('{{ section.settings.bg_image | img_url: '2000x' }}');"
  {% endif %}
>
  <div class="page-width">
    <h2 class="career-title">{{ section.settings.title }}</h2>

    <div class="career-content">
      <div class="content-left">
        {% if section.settings.content_image != blank %}
          <img
            src="{{ section.settings.content_image | img_url: '800x' }}"
            alt="事业财富风水布局"
            width="800"
            height="800"
            loading="lazy"
            style="max-width: 100%; height: auto;"
          >
        {% endif %}
      </div>
      <div class="content-right">
        <div class="content-text">
          <div>{{ section.settings.content_text }}</div>
          {% if section.settings.button_text != blank %}
            <a href="{{ section.settings.button_link }}" class="button fengshui-button">
              {{ section.settings.button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .fengshui-career-section {
    padding: 60px 0;
    background-size: cover;
    background-position: center;
    position: relative;
  }
  .fengshui-career-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ section.settings.bg_color }};
    opacity: 0.85;
    z-index: 0;
  }
  .fengshui-career-section .page-width {
    position: relative;
    z-index: 1;
  }

  .career-title {
    text-align: center;
    font-size: 2.2rem;
    color: #5c3a21;
    margin-bottom: 50px;
  }

  .career-content {
    display: flex;
    gap: 40px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .content-left {
    flex: 1;
  }
  .content-left img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }

  .content-right {
    flex: 1;
    display: flex;
    align-items: center;
  }
  .content-text {
    font-size: 1.5rem;
    line-height: 1.8;
    color: #555;
    margin-bottom: 20px;
  }

  .fengshui-button {
    background-color: #8b4513;
    color: white;
    padding: 12px 24px;
    border-radius: 4px;
    text-decoration: none;
    display: inline-block;
    transition: background-color 0.3s;
  }

  .fengshui-button:hover {
    background-color: #5c3a21;
  }

  @media (max-width: 768px) {
    .career-content {
      flex-direction: column;
    }
    .career-title {
      font-size: 1.8rem;
    }
  }
</style>

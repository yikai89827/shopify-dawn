{%- liquid
  assign heading = section.settings.heading
  assign blurb = section.settings.blurb
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
-%}

<div class="about-section">
  <h2 class="section-heading">{{ heading }}</h2>
  <div class="brand-blurb">
    {{ blurb }}
  </div>
  <a href="{{ cta_link }}" class="button">{{ cta_text }}</a>
</div>

{% schema %}
{
  "name": "About Preview",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "区块标题",
      "default": "About Preview"
    },
    {
      "type": "richtext",
      "id": "blurb",
      "label": "Poetic brand blurb"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "按钮文字",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "按钮链接"
    }
  ],
  "presets": [
    {
      "name": "About Preview"
    }
  ]
}
{% endschema %}

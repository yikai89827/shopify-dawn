{% schema %}
{
  "name": "风水布置区块",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "Powerful Healing Starts with Personalized Feng Shui Arrangement"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "副标题",
      "default": "The ancient art of harmonizing energy flow"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "风水装饰品图片"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "描述内容",
      "default": "<p>Feng Shui: The ancient art of harmonizing energy flow. Scientifically balance your space, enhance environmental vibes, and elevate daily life with natural vitality.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "按钮文字",
      "default": "Unlock Custom Feng Shui Solution"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "按钮链接"
    }
  ],
  "presets": [
    {
      "name": "风水布置区块",
      "category": "自定义区块"
    }
  ]
}
{% endschema %}

<div class="fengshui-section">
  <div class="page-width">
    <div class="fengshui-container">
      <div class="fengshui-display">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | img_url: '800x' }}"
            alt="风水装饰品"
            class="fengshui-image"
            width="800"
            height="auto"
            loading="lazy"
          >
        {% endif %}
      </div>
      <div class="fengshui-content">
        <div class="fengshui-hero">
          <h1 class="fengshui-title">{{ section.settings.title }}</h1>
          <p class="fengshui-subtitle">{{ section.settings.subtitle }}</p>
        </div>
        <div class="fengshui-description">
          <span>{{ section.settings.description }}</span>
          {% if section.settings.button_text != blank %}
            <a href="{{ section.settings.button_link }}" class="button fengshui-button">
              {{ section.settings.button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .fengshui-section {
    padding: 50px 0;
    background: linear-gradient(135deg, #f5f0e6 0%, #e8d9c5 100%);
  }

  .fengshui-hero {
    text-align: center;
    margin-bottom: 50px;
  }

  .fengshui-title {
    font-size: 2.5rem;
    color: #5c3a21;
    margin-bottom: 15px;
    font-weight: 400;
  }

  .fengshui-subtitle {
    font-size: 1.2rem;
    color: #8b4513;
    margin: 0;
  }

  .fengshui-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
  }

  .fengshui-image {
    width: 100%;
    border-radius: 8px;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
  }

  .fengshui-description {
    font-size: 1.5rem;
    line-height: 1.8;
    color: #333;
    margin-bottom: 30px;
  }

  .fengshui-button {
    background-color: #8b4513;
    color: white;
    padding: 12px 30px;
    border-radius: 4px;
    font-size: 1.5rem;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .fengshui-button:hover {
    background-color: #5c3a21;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .fengshui-container {
      grid-template-columns: 1fr;
    }

    .fengshui-title {
      font-size: 2rem;
    }
  }
</style>
